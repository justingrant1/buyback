# ─────────────────────────────────────────────────────────────────────────────
# Witter Coin — Buyback Portal  ·  environment variables
# Copy to `.env.local` and fill in. Anything marked OPTIONAL can be left blank;
# the related feature degrades to a safe stub so you can run end-to-end locally.
# ─────────────────────────────────────────────────────────────────────────────

# ---- App / Auth ----
APP_BASE_URL=http://localhost:3000        # used to build approve-offer links in emails
APP_PASSWORD=change-me                     # single shared staff password (Marley/Ben)
SESSION_SECRET=generate-a-long-random-string

# ---- Vision (slab photo → fields). Reused from the Slab Pricer app ----
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=                            # legacy fallback only
OPENAI_VISION_MODEL=gpt-4o

# ---- CDN / Greysheet (bid/ask pricing) ----
CDN_BASE_URL=https://cpgpublicapiv2beta.greysheet.com
CDN_API_KEY=
CDN_API_TOKEN=

# ---- PCGS public API (cert lookups) ----
PCGS_API_BASE_URL=https://api.pcgs.com/publicapi
PCGS_API_TOKEN=

# ---- Airtable (dedicated "BuyBack" base) ----
# Base + tables are already provisioned (see README → Airtable schema).
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=appFojtGFQF3Ga4Tx
AIRTABLE_CUSTOMERS_TABLE=Customers
AIRTABLE_BUYBACKS_TABLE=Buybacks
AIRTABLE_ITEMS_TABLE=Buyback Items


# ---- Shippo (prepaid FedEx labels). OPTIONAL: stubs a fake label when blank ----
SHIPPO_API_TOKEN=
SHIP_TO_NAME=Witter Coin — Buybacks
SHIP_TO_STREET=
SHIP_TO_CITY=
SHIP_TO_STATE=
SHIP_TO_ZIP=
SHIP_TO_PHONE=
SHIP_TO_EMAIL=

# ---- SendGrid (offer + label emails). OPTIONAL: logs instead of sending ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=buyback@wittercoin.com
SENDGRID_FROM_NAME=Witter Coin Buybacks

# ---- Metals spot (junk silver / melt). OPTIONAL ----
METALS_API_KEY=
METALS_API_BASE_URL=https://api.metals.dev/v1

# ---- Business rules (tune to Marley's thresholds) ----
VIP_THRESHOLD=20000        # above this $ → personal/VIP touch, no automation
LOW_VALUE_FLOOR=2500       # below this $ → low-value/junk, deprioritized
DEFAULT_MARGIN=0.15        # target margin per batch (10–20%)
JUNK_MARGIN=0.05           # thinner margin on junk silver (our floor)
